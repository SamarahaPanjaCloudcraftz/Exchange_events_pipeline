# Copy to .env and fill in. Secrets are read from the environment, never committed.
# Loaded by config/loader.py via pydantic-settings.

# --- Storage ---
# SQLite is the default; no config needed for local dev. On a real server, set
# this to an absolute path on persistent disk, OUTSIDE the git checkout (so
# `git checkout` during a redeploy never touches the database file) -- e.g.
# EXCHANGE_EVENTS_SQLITE_PATH=/opt/exchange-events/data/exchange_events.db
EXCHANGE_EVENTS_SQLITE_PATH=

# Set a DSN to use Postgres instead (not the chosen path for this deployment).
# EXCHANGE_EVENTS_PG_DSN=postgresql://user:pass@localhost:5432/exchange_events

# --- Economic-release waterfall (tier 1-3 = official/free, no anti-bot walls) ---
# See DECISIONS.md "Economic-release waterfall" for the full design + rationale.

# Tier 1 (primary, covers 6 of 7 releases): free key -
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Tier 2 (official backstop for NFP/CPI/PPI/JOLTS): optional (works unkeyed at a
# lower rate limit), free key - https://www.bls.gov/developers/
BLS_API_KEY=

# Tier 3 (official backstop for PCE): free UserID -
# https://apps.bea.gov/api/signup/
BEA_API_KEY=

# Best-effort only, ISM Manufacturing PMI (no free official source exists — see
# adapters/ism.py). Leave blank until a specific aggregator is evaluated/chosen.
ISM_API_KEY=
ISM_URL=

# CME Reference Data API v3 (OAuth) — free official CME Group Customer Center
# credential, distinct from the paid real-time market-data feeds. Covers holidays,
# trading hours, and instrument lifecycle/expiry dates. Not yet wired into
# config/loader.py — placeholder only until the adapter is built.
CME_API_ID=
CME_API_SECRET=

# --- Notification: Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=

# --- Notification: Microsoft Teams (Incoming Webhook) ---
TEAMS_WEBHOOK_URL=

# --- Notification: alert recipient ---
# Overrides the placeholder address in config/defaults.toml's "team_trading"
# recipient group (routed CRITICAL alerts go here). Leave blank to keep the
# placeholder (no real email ever committed).
ALERT_RECIPIENT_EMAIL=
ALERT_RECIPIENT_NAME=
